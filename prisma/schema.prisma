// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// المستخدمين
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String?
  password         String?
  avatar           String?
  phone            String?
  role             String    @default("trader")
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  // حقول استعادة الباسوورد
  resetToken       String?
  resetTokenExpiry DateTime?
  
  // حقول تأكيد البريد الإلكتروني
  verifyToken      String?
  verifyTokenExpiry DateTime?
  
  // Relations
  portfolios        Portfolio[]
  tradingAccounts   TradingAccount[]
  trades            Trade[]
  tradingPlans      TradingPlan[]
  setups            Setup[]
  riskProfiles      RiskProfile[]
  journals          TradingJournal[]
  sessions          SessionReview[]
  psychologyLogs    PsychologyLog[]
  audits            Audit[]
  subscription      Subscription?
  strategies        Strategy[]
  zenStates         ZenState[]
  tradingRules      TradingRule[]
  riskUsages        RiskUsage[]
  riskAlerts        RiskAlert[]
  riskChecks        RiskCheck[]
  webhooks          TradingViewWebhook[]
  metaApiTokens     MetaApiToken[]
  dailySyncLogs     DailySyncLog[]
  
  // Auth Relations
  authAccounts     AuthAccount[]
  authSessions     AuthSession[]
  twoFactorAuth    TwoFactorAuth?
  loginHistory     LoginHistory[]
  auditLogs        AuditLog[]

  @@index([email])
  @@map("users")
}

// المحافظ الاستثمارية
model Portfolio {
  id                String   @id @default(cuid())
  userId            String
  name              String
  description       String?
  totalValue        Float    @default(0)
  cashBalance       Float    @default(0)
  investedAmount    Float    @default(0)
  profitLoss        Float    @default(0)
  profitLossPercent Float    @default(0)
  currency          String   @default("USD")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingAccounts TradingAccount[]
  trades          Trade[]

  @@index([userId])
}

// حسابات التداول الموحدة (Broker, Prop Firm, Indices, Stocks)
model TradingAccount {
  id             String   @id @default(cuid())
  userId         String
  portfolioId    String?
  name           String
  accountType    String   // "broker" | "propfirm" | "indices" | "stocks"
  currency       String   @default("USD")
  balance        Float    @default(0)
  equity         Float    @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Broker Fields (MT4/MT5)
  broker          String?
  platform        String?  // "MT4" | "MT5"
  accountNumber   String?
  server          String?
  connectionMethod String? // "manual" | "metaapi" | "webhook"
  connectionStatus String? @default("disconnected") // "connected" | "disconnected" | "syncing" | "error"
  lastSync        DateTime?
  autoSync        Boolean  @default(false)
  metaApiTokenId  String?
  
  // Prop Firm Fields
  propFirmCompany String?
  propFirmPhase   String?  // "Phase 1" | "Phase 2" | "Funded"
  challengeType   String?  // "Challenge" | "Verification" | "Funded"
  challengeTarget Float?  // الهدف المطلوب (%)
  challengeStart  DateTime?
  challengeEnd    DateTime?
  daysRemaining   Int?
  
  // Prop Firm Drawdown Limits
  dailyDrawdownLimit Float?
  dailyDrawdownUsed  Float    @default(0)
  maxDailyLoss       Float?   // بالدولار
  
  overallDrawdownLimit Float?
  overallDrawdownUsed  Float    @default(0)
  maxOverallLoss       Float?   // بالدولار
  
  // Prop Firm Progress
  profitTarget    Float?   // الهدف بالدولار
  currentProfit   Float    @default(0)
  
  // Indices Fields
  indexSymbol     String?  // "DAX" | "NASDAQ" | "S&P500"
  exchange        String?
  lotSize         Float?
  
  // Stocks Fields
  exchangeName    String?  // "NASDAQ" | "Tadawul" | "LSE"
  stocksList      String?  // JSON array of stock symbols
  stocksCount     Int?
  
  // Health Metrics
  maxDrawdown     Float?
  currentDrawdown Float    @default(0)
  healthStatus    String   @default("safe") // "safe" | "warning" | "danger"
  
  // Sparkline Data (آخر 7 أيام)
  sparklineData   String?  // JSON array of 7 equity values
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio       Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  trades          Trade[]
  metaApiToken    MetaApiToken? @relation(fields: [metaApiTokenId], references: [id], onDelete: SetNull)
  dailySyncLogs   DailySyncLog[]
    webhooks        TradingViewWebhook[]

  @@index([userId])
  @@index([portfolioId])
  @@index([accountType])
  @@index([connectionStatus])
}

// MetaAPI Token للربط مع MT4/MT5
model MetaApiToken {
  id            String   @id @default(cuid())
  userId        String
  name          String
  token         String   // مشفر
  accountId     String   // MetaAPI account ID
  isActive      Boolean  @default(true)
  lastUsed      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingAccounts  TradingAccount[]
  
  @@index([userId])
}

// TradingView Webhooks
model TradingViewWebhook {
  id           String   @id @default(cuid())
  userId       String
  accountId    String?
  webhookToken String   @unique // token فريد للمستخدم
  payload      String   // JSON payload من TradingView
  processed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account TradingAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([webhookToken])
  @@index([processed])
}

// سجل المزامنة اليومية
model DailySyncLog {
  id              String   @id @default(cuid())
  accountId       String
  userId          String
  syncDate        DateTime @default(now())
  balanceBefore   Float
  balanceAfter    Float
  equityBefore    Float
  equityAfter     Float
  tradesSynced    Int      @default(0)
  syncStatus      String   @default("pending") // "success" | "failed" | "pending"
  errorMessage    String?
  createdAt       DateTime @default(now())
   user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([accountId])
  @@index([syncDate])
}

// الصفقات
model Trade {
  id               String    @id @default(cuid())
  userId           String
  portfolioId      String?
  accountId        String?
  symbol           String
  type             String
  status           String    @default("open")
  entryPrice       Float
  exitPrice        Float?
  quantity         Float
  lotSize          Float     @default(1)
  stopLoss         Float?
  takeProfit       Float?
  commission       Float     @default(0)
  swap             Float     @default(0)
  profitLoss       Float     @default(0)
  profitLossPoints Float?
  pipValue         Float?
  notes            String?
  strategy         String?
  entryReason      String?
  exitReason       String?
  emotions         String?
  confidence       Int?
  openedAt         DateTime  @default(now())
  closedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio Portfolio?       @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  account   TradingAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([symbol])
  @@index([status])
  @@index([openedAt])
}

// خطط التداول
model TradingPlan {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String    @default("daily")
  goals       String?
  rules       String?
  strategies  String?
  riskRules   String?
  maxTrades   Int?
  maxRisk     Float?
  status      String    @default("active")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

// الإعدادات والأنماط
model Setup {
  id               String    @id @default(cuid())
  userId           String
  name             String
  description      String?
  category         String?
  timeframe        String?
  conditions       String?
  entryRules       String?
  exitRules        String?
  stopLossRules    String?
  takeProfitRules  String?
  riskReward       Float?
  successRate      Float?
  isActive         Boolean   @default(true)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

// ملف المخاطر
model RiskProfile {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String?
  accountName          String?
  accountType          String?
  name                 String
  description          String?
  riskTolerance        String    @default("moderate")
  riskDegree           Int       @default(5)
  maxDailyLoss         Float?
  maxWeeklyLoss        Float?
  maxMonthlyLoss       Float?
  maxDrawdown          Float?
  maxPositionSize      Float?
  maxRiskPerTrade      Float?
  maxCorrelatedTrades  Int?
  maxLeverage          Float?
  stopLossRequired     Boolean   @default(false)
  takeProfitRequired   Boolean   @default(false)
  riskRewardMin        Float?
  isConfigured         Boolean   @default(false)
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
}

// يومية التداول
model TradingJournal {
  id                   String    @id @default(cuid())
  userId               String
  date                 DateTime  @default(now())
  type                 String    @default("daily")
  marketAnalysis       String?
  keyLevels            String?
  supportLevels        String?
  resistanceLevels     String?
  trendDirection       String?
  expectedVolatility   String?
  economicEvents       String?
  tradingPlan          String?
  strategiesToUse      String?
  dailyGoal            String?
  maxTrades            Int?      @default(3)
  riskPlan             String?
  sessionType          String?
  sessionStart         String?
  sessionEnd           String?
  tradesPlanned        Int?      @default(0)
  tradesExecuted       Int?      @default(0)
  entrySetups          String?
  priceActionObs       String?
  executionNotes       String?
  marketBehavior       String?
  realTimeObservations String?
  totalTrades          Int?      @default(0)
  winningTrades        Int?      @default(0)
  losingTrades         Int?      @default(0)
  totalProfitLoss      Float?    @default(0)
  sessionResult        String?
  executionQuality     Int?      @default(5)
  planAdherence        Int?      @default(5)
  riskAdherence        Int?      @default(5)
  emotionsBefore       String?
  emotionsDuring       String?
  emotionsAfter        String?
  whatWentWell         String?
  whatNeedsImprovement String?
  lessonsLearned       String?
  tomorrowPlan         String?
  title                String?
  sentiment            String?
  pointsOfInterest     String?
  expectedScenario     String?
  technicalStrategy    String?
  keyLevelsPre         String?
  marketCondition      String?
  entryModels          String?
  priceAction          String?
  tradeExecution       String?
  observations         String?
  result               String?
  improvementsPost     String?
  plannedTrades        String?
  actualTrades         String?
  lessons              String?
  mistakes             String?
  improvements         String?
  mood                 Int?
  energy               Int?
  focus                Int?
  confidence           Int?
  notes                String?
  attachments          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([type])
  @@index([sessionType])
}

// مراجعات الجلسات
model SessionReview {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime  @default(now())
  session         String    @default("london")
  marketOpen      Boolean   @default(true)
  marketCondition String?
  volatility      String?
  volume          String?
  tradesPlanned   Int       @default(0)
  tradesTaken     Int       @default(0)
  tradesWon       Int       @default(0)
  tradesLost      Int       @default(0)
  profitLoss      Float     @default(0)
  rulesFollowed   Boolean?
  emotions        String?
  mistakes        String?
  improvements    String?
  notes           String?
  rating          Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([session])
}

// سجل علم النفس
model PsychologyLog {
  id               String    @id @default(cuid())
  userId           String
  date             DateTime  @default(now())
  type             String    @default("check-in")
  tradeId          String?
  emotion          String?
  emotionIntensity Int?
  trigger          String?
  reaction         String?
  outcome          String?
  copingStrategy   String?
  lessons          String?
  recommendations  String?
  stress           Int?
  discipline       Int?
  patience         Int?
  confidence       Int?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([type])
}

// التدقيق
model Audit {
  id              String    @id @default(cuid())
  userId          String
  type            String
  title           String
  description     String?
  period          String?
  startDate       DateTime?
  endDate         DateTime?
  findings        String?
  recommendations String?
  improvements    String?
  status          String    @default("pending")
  score           Int?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
}

// الاشتراكات
model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  plan                  String    @default("free")
  status                String    @default("active")
  startDate             DateTime  @default(now())
  endDate               DateTime?
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  cancelAtPeriodEnd     Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  usage Usage[]

  @@index([userId])
  @@index([plan])
  @@index([status])
}

// الاستخدام
model Usage {
  id              String    @id @default(cuid())
  subscriptionId  String
  userId          String
  type            String
  count           Int       @default(0)
  limit           Int?
  period          String    @default("monthly")
  resetAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([userId])
  @@index([type])
}

// الاستراتيجيات
model Strategy {
  id            String    @id @default(cuid())
  userId        String
  name          String
  description   String?
  category      String?
  timeframe     String?
  entryRules    String?
  exitRules     String?
  riskRules     String?
  totalTrades   Int       @default(0)
  winningTrades Int       @default(0)
  losingTrades  Int       @default(0)
  profitLoss    Float     @default(0)
  winRate       Float?
  avgRRR        Float?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

// حالات ZEN
model ZenState {
  id           String    @id @default(cuid())
  userId       String
  type         String
  duration     Int?
  moodBefore   Int?
  moodAfter    Int?
  stressBefore Int?
  stressAfter  Int?
  focusBefore  Int?
  focusAfter   Int?
  notes        String?
  completedAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

// قواعد التداول
model TradingRule {
  id             String    @id @default(cuid())
  userId         String
  name           String
  description    String?
  category       String    @default("entry")
  compliance     Int       @default(100)
  violations     Int       @default(0)
  violationCost  Float     @default(0)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

// استخدام المخاطر
model RiskUsage {
  id              String    @id @default(cuid())
  userId          String
  riskProfileId   String
  date            DateTime  @default(now())
  dailyLoss       Float     @default(0)
  dailyTrades     Int       @default(0)
  dailyRiskUsed   Float     @default(0)
  weeklyLoss      Float     @default(0)
  weeklyTrades    Int       @default(0)
  weeklyRiskUsed  Float     @default(0)
  monthlyLoss     Float     @default(0)
  monthlyTrades   Int       @default(0)
  monthlyRiskUsed Float     @default(0)
  riskBySymbol    String?
  openTrades      Int       @default(0)
  totalExposure   Float     @default(0)
  marginUsed      Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([riskProfileId])
  @@index([date])
}

// تنبيهات المخاطر
model RiskAlert {
  id             String    @id @default(cuid())
  userId         String
  riskProfileId  String
  type           String
  severity       String    @default("warning")
  title          String
  message        String
  currentValue   Float?
  limitValue     Float?
  percentage     Float?
  isRead         Boolean   @default(false)
  isResolved     Boolean   @default(false)
  resolvedAt     DateTime?
  tradeId        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([riskProfileId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// سجل فحص المخاطر
model RiskCheck {
  id               String    @id @default(cuid())
  userId           String
  riskProfileId    String
  tradeId          String?
  symbol           String
  tradeType        String
  entryPrice       Float
  stopLoss         Float?
  takeProfit       Float?
  quantity         Float
  lotSize          Float     @default(1)
  riskAmount       Float     @default(0)
  riskPercent      Float     @default(0)
  rewardAmount     Float     @default(0)
  riskRewardRatio  Float?
  passed           Boolean   @default(false)
  violations       String?
  warnings         String?
  userDecision     String?
  modifiedValues   String?
  createdAt        DateTime  @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([riskProfileId])
  @@index([passed])
  @@index([createdAt])
}

// NextAuth.js Models
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model TwoFactorAuth {
  id          String   @id @default(cuid())
  userId      String   @unique
  secret      String
  enabled     Boolean  @default(false)
  backupCodes String[]
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_auth")
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  location   String?
  successful Boolean  @default(true)
  method     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}

// سجل التدقيق والمراجعة
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}